<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet feed configuration for the ResoniteAIBridge solution.

  - nuget.org: 一般的な OSS パッケージ (Grpc.Tools, Google.Protobuf, xunit, ...)
  - bepinex:   BepInEx.Core / BepInEx.NET.Common など、BepisLoader が依存する
               プレリリース (6.0.0-be.*) を提供する公式 feed
  - resonite-modding: Remora.Resonite.Sdk が `RestoreAdditionalProjectSources`
               で参照する。Mod.BepisLoader.targets が依存する
               BepInExResoniteShim / BepisResoniteWrapper / ResonitePluginInfoProps
               が置かれている。
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="bepinex" value="https://nuget.bepinex.dev/v3/index.json" />
    <add key="resonite-modding" value="https://nuget-modding.resonite.net/v3/index.json" />
  </packageSources>
</configuration>
